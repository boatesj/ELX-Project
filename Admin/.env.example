
# Admin/.env.example
# Ellcworth Express — Admin Portal
# Copy to .env.local (or .env) and set real values
# IMPORTANT: Vite env vars must start with VITE_

# Root API (used for /auth, /config, /health, /docs)
# No trailing slash
VITE_API_BASE_URL=http://localhost:8000

# Admin-only endpoints (system ops under /admin/*)
# No trailing slash
VITE_ADMIN_API_BASE_URL=http://localhost:8000/admin

# Optional environment hint
VITE_APP_ENV=development
