# Admin/.env.example
# Ellcworth Express — Admin Portal
# Copy to .env.local (or .env) and set real values.
# IMPORTANT: Vite env vars must start with VITE_

# -------------------------------------------------
# Backend API root (NO trailing slash)
# NOTE:
# - Canonical business APIs live under /api/v1
# - Admin request helpers append /api/v1 internally
# -------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000

# -------------------------------------------------
# Optional: Admin system / ops endpoints
# (Only if /admin/* routes are used explicitly)
# -------------------------------------------------
VITE_ADMIN_API_BASE_URL=http://localhost:8000/admin

# -------------------------------------------------
# Environment hint (optional)
# -------------------------------------------------
VITE_APP_ENV=development
