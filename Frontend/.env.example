# Frontend/.env.example
# Ellcworth Express — Frontend (Public site + Customer portal)
# Copy to .env.local (or .env) and set real values.
# IMPORTANT: Vite env vars must start with VITE_

# Backend API origin (NO trailing slash)
# Local dev:
VITE_API_URL=http://localhost:8000

# Optional: if you ever switch the API base prefix in one place
# (Most calls already hardcode /api/v1 in paths — keep it consistent.)
VITE_API_PREFIX=/api/v1

# Support / contact (used in CTA buttons / footers if wired)
VITE_SUPPORT_EMAIL=info@ellcworth.com
VITE_SUPPORT_PHONE=+442089796054

# Environment hint (optional)
VITE_APP_ENV=development
