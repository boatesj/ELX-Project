# Ellcworth Backend (.env.example)
# Copy to: Backend/.env
# IMPORTANT:
# - Do NOT commit real secrets or production DB URIs.
# - All values here are placeholders or safe local defaults.

# -----------------------
# Server
# -----------------------
PORT=8000
NODE_ENV=development

# -----------------------
# CORS (used by Backend/index.js)
#
# - CLIENT_URL, ADMIN_URL, ALLOWED_ORIGINS are comma-separated lists.
# - In development, the backend may fail-open if allowlists are empty and
#   NODE_ENV != production, but these are defined explicitly for clarity.
# - In production, ALLOWED_ORIGINS MUST be locked.
# -----------------------
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:3000
ALLOWED_ORIGINS=

# -----------------------
# Security / Rate Limiting
# -----------------------
RATE_LIMIT_PER_MINUTE=240

# -----------------------
# Database
#
# Choose ONE in your real .env.
# Do NOT place real credentials in this file.
# -----------------------

# Local development
MONGO_URI=mongodb://127.0.0.1:27017/ellcworth

# Production example (commented — replace in real .env only):
# MONGO_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER>/<DB_NAME>?retryWrites=true&w=majority

# -----------------------
# Authentication / JWT
#
# Backend supports JWT_SECRET (preferred) or JWT_SEC (legacy fallback).
# Use a long, random string in real environments.
# -----------------------
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES=10d

# -----------------------
# Backups (if enabled)
# -----------------------
BACKUP_DIR=./backups

# -----------------------
# Admin-only mode (if used)
# -----------------------
ADMIN_ONLY=true

# -----------------------
# Mail / Notifications
#
# Only required if email sending is enabled.
# Use provider-specific credentials in real .env files only.
# -----------------------
MAIL_TRANSPORT=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=change_me@example.com
SMTP_PASS=change_me_app_password
EMAIL_FROM=no-reply@ellcworth.com
