# Ellcworth BackgroundServices (.env.example)
# Copy to: BackgroundServices/.env
# Phase 5 readiness: minimal, explicit, reproducible.
# Do NOT commit real secrets or production credentials.

# -----------------------
# Runtime
# -----------------------
NODE_ENV=development
PORT=8001

# -----------------------
# Database
#
# REQUIRED:
# Background services require MongoDB access.
# Use a local Mongo instance for development.
# -----------------------
MONGO_URI=mongodb://127.0.0.1:27017/ellcworth

# Production example (DO NOT commit real values):
# MONGO_URI=mongodb+srv://<DB_USER>:<DB_PASSWORD>@<CLUSTER>/<DB_NAME>?retryWrites=true&w=majority

# -----------------------
# Backend API
#
# Canonical business APIs live under /api/v1
# Append /api/v1 in code where required.
# -----------------------
API_BASE_URL=http://localhost:8000

# -----------------------
# Authentication (ONLY if used)
#
# Required only if BackgroundServices issue or verify JWTs.
# -----------------------
JWT_SECRET=change_me_to_a_long_random_string

# -----------------------
# Logging
# -----------------------
LOG_LEVEL=info
